---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  ogType?: string
}

const {
  title,
  description = 'Free practical guides on AI and automation, by Jun Seng.',
  ogType = 'website',
} = Astro.props
const canonical = new URL(Astro.url.pathname, Astro.site)
const ogImage = new URL('/og-image.png', Astro.site)
const nav = [
  { href: '/', label: 'Home' },
  { href: '/guides/', label: 'Free guides' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
]
const path = Astro.url.pathname
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="fuvMNTIEDfiYaMgh5AKLWDvXFlWaO8JyJsqcUIAuTQ0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Jun Seng" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <slot name="head" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect x='1' y='1' width='30' height='30' rx='6' fill='%23E6572E' stroke='%23161311' stroke-width='2'/%3E%3Ctext x='16' y='23' text-anchor='middle' font-family='Arial Black,sans-serif' font-weight='900' font-size='18' fill='%23FBF1DD'%3EJ%3C/text%3E%3C/svg%3E"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="nav-bar">
      <header class="wrap">
        <nav>
          <a class="logo display" href="/">Jun Seng.</a>
          <ul class="nav-links">
            {nav.map((n) => (
              <li><a href={n.href} class:list={{ active: path === n.href }}>{n.label}</a></li>
            ))}
          </ul>
          <a class="btn btn-pill" href="/contact/">Say hi</a>
        </nav>
      </header>
    </div>

    <main><slot /></main>

    <footer>
      <div class="halftone ht-fade-tl"></div>
      <div class="wrap footer-inner">
        <span class="foot-logo display">Jun Seng.</span>
        <span>built with AI, shipped by a human. © 2026 Jun Seng</span>
      </div>
    </footer>
  </body>
</html>

<style>
  .nav-bar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--cream);
    border-bottom: var(--border-w) solid var(--ink);
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
  }
  .logo { font-size: 1.55rem; color: var(--ink); text-decoration: none; }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 30px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-links a {
    color: var(--ink);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.98rem;
    position: relative;
  }
  .nav-links a:hover,
  .nav-links a.active {
    text-decoration: underline wavy var(--orange) 2px;
    text-underline-offset: 5px;
  }

  footer {
    position: relative;
    overflow: hidden;
    border-top: var(--border-w) solid var(--ink);
    background: var(--off-white);
    margin-top: 3rem;
  }
  .footer-inner {
    padding: 30px 0 34px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 14px;
  }
  .foot-logo { font-size: 1.2rem; }
  footer .halftone { bottom: -60px; left: 30%; width: 220px; height: 200px; z-index: 0; }

  @media (max-width: 960px) {
    .nav-links { gap: 16px; }
  }
  @media (max-width: 640px) {
    nav { flex-wrap: wrap; gap: 10px 16px; }
    .nav-links { order: 3; width: 100%; justify-content: space-between; gap: 8px; }
  }
</style>
