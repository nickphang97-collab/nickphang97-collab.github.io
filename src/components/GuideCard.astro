---
interface Props {
  slug: string
  title: string
  topic: string
  tool: string
  index: number
  placeholder?: boolean
}

const { slug, title, topic, tool, index, placeholder = false } = Astro.props
const fills = ['fill-orange', 'fill-mustard', 'fill-off']
const num = String(index + 1).padStart(2, '0')
---

<article class:list={['card', 'guide', fills[index % 3]]} data-topic={topic} data-tool={tool}>
  <span class="num display">{num}</span>
  <h3>{title}</h3>
  <p class="tags">
    <span class="chip">{topic}</span>
    <span class="chip">{tool}</span>
    {placeholder && <span class="chip">coming soon</span>}
  </p>
  {placeholder ? (
    <span class="read soon">In the works →</span>
  ) : (
    <a class="read" href={`/guides/${slug}/`}>Read the guide →</a>
  )}
</article>

<style>
  .guide {
    display: flex;
    flex-direction: column;
    min-height: 250px;
  }
  .guide h3 { margin: 10px 0 14px; }
  .num {
    position: absolute;
    top: -18px;
    left: 22px;
    background: var(--ink);
    color: var(--cream);
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    border: var(--border-w) solid var(--ink);
  }
  .tags { display: flex; gap: 6px; flex-wrap: wrap; margin: 0 0 22px; }
  .chip {
    font-size: 0.78rem;
    font-weight: 700;
    padding: 2px 10px;
    border: 2px solid currentColor;
    border-radius: 999px;
    opacity: 0.85;
  }
  .read {
    margin-top: auto;
    align-self: flex-start;
    font-weight: 800;
    text-decoration: none;
    color: inherit;
    border-bottom: 3px solid currentColor;
    padding-bottom: 2px;
  }
  .soon { opacity: 0.6; border-bottom-style: dashed; }
</style>
