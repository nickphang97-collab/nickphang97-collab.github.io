---
import Base from '../layouts/Base.astro'
---

<Base title="Message sent — Jun Seng" description="Your message is on its way to Jun Seng.">
  <section>
    <div class="wrap box">
      <svg class="sticker sticker--sm" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="50" cy="50" r="42" fill="var(--mustard)" stroke="var(--ink)" stroke-width="4"/>
        <circle cx="34" cy="42" r="6" fill="var(--ink)"/>
        <circle cx="66" cy="42" r="6" fill="var(--ink)"/>
        <path d="M28,60 Q50,80 72,60" stroke="var(--ink)" stroke-width="5" fill="none" stroke-linecap="round"/>
      </svg>
      <h1 class="display">Got it. <span class="hl">Talk soon.</span></h1>
      <p>
        Your message is in my inbox. I read every one myself and usually reply
        within a day (Malaysia time).
      </p>
      <div class="actions">
        <a class="btn btn-primary" href="/guides/">Read a guide while you wait</a>
        <a class="btn btn-secondary" href="/">Back home</a>
      </div>
    </div>
  </section>
</Base>

<style>
  section { padding: 5rem 0; }
  .box { max-width: 40rem; text-align: center; }
  .sticker { width: 90px; margin-bottom: 24px; }
  h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); margin-bottom: 20px; }
  p { font-size: 1.15rem; font-weight: 500; max-width: 42ch; margin: 0 auto 32px; }
  .actions { display: flex; gap: 18px; justify-content: center; flex-wrap: wrap; }
</style>
