---
import { getCollection, render } from 'astro:content'
import Base from '../../layouts/Base.astro'
import NewsletterBox from '../../components/NewsletterBox.astro'

export async function getStaticPaths() {
  const guides = await getCollection('guides')
  return guides.map((g) => ({ params: { slug: g.id }, props: { guide: g } }))
}

const { guide } = Astro.props
const { Content } = await render(guide)

const articleLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.data.title,
  description: guide.data.description,
  datePublished: guide.data.date.toISOString().slice(0, 10),
  author: { '@type': 'Person', name: 'Jun Seng', url: new URL('/about/', Astro.site) },
  mainEntityOfPage: new URL(`/guides/${guide.id}/`, Astro.site),
})
---

<Base title={`${guide.data.title} — Jun Seng`} description={guide.data.description} ogType="article">
  <script is:inline type="application/ld+json" set:html={articleLd} slot="head" />
  <section>
    <div class="wrap article">
      <p class="tags">
        <span class="eyebrow">{guide.data.topic}</span>
        <span class="eyebrow tool">{guide.data.tool}</span>
      </p>
      <h1 class="display">{guide.data.title}</h1>
      <p class="desc">{guide.data.description}</p>
      <hr />
      <div class="content">
        <Content />
      </div>
      <NewsletterBox />
      <p class="back"><a href="/guides/">← Back to all guides</a></p>
    </div>
  </section>
</Base>

<style>
  .article { max-width: 46rem; }
  .tags { display: flex; gap: 10px; margin-bottom: 1.6rem; }
  .eyebrow.tool { background: var(--orange); color: var(--off-white); transform: rotate(1.5deg); }
  h1 { font-size: clamp(1.9rem, 4vw, 2.9rem); line-height: 1.08; }
  .desc { font-size: 1.18rem; font-weight: 500; }
  hr { border: none; border-top: var(--border-w) solid var(--ink); margin: 2rem 0; }
  .back { margin-top: 3rem; }
  .back a {
    font-weight: 800;
    text-decoration: none;
    border-bottom: 3px solid var(--orange);
    padding-bottom: 2px;
  }

  .content :global(h2) {
    font-size: 1.7rem;
    margin: 2.2rem 0 0.8rem;
  }
  .content :global(h3) { margin: 1.8rem 0 0.6rem; }
  .content :global(a) { color: var(--ink); text-decoration: underline wavy var(--orange) 2px; text-underline-offset: 4px; }
  .content :global(code) {
    background: var(--off-white);
    border: 2px solid var(--ink);
    border-radius: 6px;
    padding: 0.05em 0.35em;
    font-size: 0.9em;
  }
  .content :global(pre) {
    background: var(--ink);
    color: var(--cream);
    border: var(--border-w) solid var(--ink);
    border-radius: 12px;
    box-shadow: 6px 6px 0 rgba(22, 19, 17, 0.25);
    padding: 1.1rem 1.3rem;
    overflow-x: auto;
  }
  .content :global(pre code) { background: none; border: none; padding: 0; font-size: 0.92em; }
  .content :global(blockquote) {
    margin: 1.4rem 0;
    padding: 0.8rem 1.2rem;
    border: var(--border-w) solid var(--ink);
    border-radius: 12px;
    background: var(--mustard);
    box-shadow: 6px 6px 0 var(--ink);
    font-weight: 600;
  }
  .content :global(blockquote p) { margin: 0; }
  .content :global(ul), .content :global(ol) { padding-left: 1.4rem; }
  .content :global(li) { margin-bottom: 0.4rem; }
  .content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1.4rem 0;
  }
  .content :global(th), .content :global(td) {
    border: 2px solid var(--ink);
    padding: 0.5rem 0.8rem;
    text-align: left;
  }
  .content :global(th) { background: var(--mustard); font-weight: 800; }
</style>
